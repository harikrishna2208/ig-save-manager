{
  "manifest_version": 3,
  "name": "Instagram Unsaver Revamped",
  "description": "Next-generation batch unsaving and downloading queue engine for Instagram.",
  "version": "6.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon-128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "permissions": [
    "downloads",
    "cookies",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://*.instagram.com/*",
    "https://i.instagram.com/*"
  ],
  "icons": {
    "128": "icon-128.png"
  }
}
