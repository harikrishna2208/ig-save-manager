{
  "name": "ig-save-manager",
  "version": "6.0.0",
  "description": "Browse, manage, and bulk-download your saved posts and collections.",
  "main": "index.js",
  "scripts": {
    "watch": "webpack --watch --mode development",
    "build": "webpack --mode production",
    "clean": "rimraf dist",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:apply": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "1.44.1",
    "@types/chrome": "0.0.268",
    "@types/node": "20.19.41",
    "@types/react": "18.3.30",
    "@types/react-dom": "18.3.7",
    "copy-webpack-plugin": "12.0.2",
    "css-loader": "7.1.2",
    "rimraf": "5.0.10",
    "style-loader": "4.0.0",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "1.6.1",
    "webpack": "5.99.9",
    "webpack-cli": "5.1.4"
  }
}
